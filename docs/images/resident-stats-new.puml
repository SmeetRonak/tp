@startuml resident-stats

skinparam defaultFontSize 13
skinparam SequenceArrowThickness 1.5
skinparam SequenceParticipantBackgroundColor #f9f9f9

title resident-stats Command

actor ":User" as User
participant "ccaLedger : CcaLedger" as CcaLedger
participant "ui : Ui" as Ui
participant "parser : Parser" as Parser
participant "command : ResidentStatsCommand" as Command
participant "residentManager : ResidentManager" as ResidentManager

ref over User, CcaLedger, Ui, Parser, Command
  SD_CommandExecution
end ref

Command -> ResidentManager : getResidentList()
activate ResidentManager
ResidentManager --> Command : residentList : ArrayList<Resident>
deactivate ResidentManager

alt no residents exist
    Command -> Ui : showMessage("No residents currently...")
    activate Ui
    Ui --> Command
    deactivate Ui
else residents exist
    Command -> Command : totalPoints(residentList)
    Command -> Command : mostActiveResidents(totalPoints)
    Command -> Ui : showResidentStats(totalPoints, mostActiveResidents)
    activate Ui
    Ui --> Command
    deactivate Ui
end

Command --> CcaLedger
deactivate Command

@enduml