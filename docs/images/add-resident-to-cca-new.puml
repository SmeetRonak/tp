@startuml add-resident-to-cca

skinparam defaultFontSize 13
skinparam SequenceArrowThickness 1.5
skinparam SequenceParticipantBackgroundColor #f9f9f9

title add-resident-to-cca Command

actor ":User" as User
participant "ccaLedger : CcaLedger" as CcaLedger
participant "ui : Ui" as Ui
participant "parser : Parser" as Parser
participant "command : AddResidentToCcaCommand" as Command
participant "ccaManager : CcaManager" as CcaManager
participant "residentManager : ResidentManager" as ResidentManager

ref over User, CcaLedger, Ui, Parser, Command
  SD_CommandExecution
end ref

Command -> CcaManager : getCCAList()
activate CcaManager
CcaManager --> Command : ccaList : ArrayList<Cca>
deactivate CcaManager

Command -> ResidentManager : getResidentList()
activate ResidentManager
ResidentManager --> Command : residentList : ArrayList<Resident>
deactivate ResidentManager

alt CCA not found
    Command -> Ui : showError("CCA not found")
    activate Ui
    Ui --> Command
    deactivate Ui
else Resident not found
    Command -> Ui : showError("Resident not found")
    activate Ui
    Ui --> Command
    deactivate Ui
else Resident already in CCA
    Command -> Ui : showError("Resident already in CCA")
    activate Ui
    Ui --> Command
    deactivate Ui
else Both found and valid
    Command -> Command : cca.addResidentToCca(resident)
    Command -> Command : resident.addCcaToResident(cca, pointsScored)
    Command -> Ui : showMessage("Resident added to CCA...")
    activate Ui
    Ui --> Command
    deactivate Ui
end

Command --> CcaLedger
deactivate Command

@enduml