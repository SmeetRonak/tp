@startuml add-resident

skinparam defaultFontSize 13
skinparam SequenceArrowThickness 1.5
skinparam SequenceParticipantBackgroundColor #f9f9f9

title add-resident Command

actor ":User" as User
participant "ccaLedger : CcaLedger" as CcaLedger
participant "ui : Ui" as Ui
participant "parser : Parser" as Parser
participant "command : AddResidentCommand" as Command
participant "residentManager : ResidentManager" as ResidentManager

ref over User, CcaLedger, Ui, Parser, Command
  SD_CommandExecution
end ref

Command -> ResidentManager : addResident(residentName, matricNumber)
activate ResidentManager

alt Resident already exists
    ResidentManager --> Command : throws DuplicateResidentException
    deactivate ResidentManager
    Command -> Ui : showError(message)
    activate Ui
    Ui --> Command
    deactivate Ui
else Resident is new
    ResidentManager --> Command : (void)
    deactivate ResidentManager
    Command -> Ui : showMessage("Resident added: ...")
    activate Ui
    Ui --> Command
    deactivate Ui
end

Command --> CcaLedger
deactivate Command

@enduml